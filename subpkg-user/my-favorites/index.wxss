.fav-page { min-height: 100vh; background: var(--background, #FAF5FF); padding-bottom: 32rpx; }

.header {
  position: sticky; top: 0; z-index: 10;
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 24rpx; background: #fff;
  border-bottom: 2rpx solid var(--border, #E9D5FF);
}
.back { width: 72rpx; color: var(--foreground, #1E1B2E); font-size: 24rpx; }
.head-title { flex: 1; color: var(--foreground, #1E1B2E); font-size: 30rpx; font-weight: 700; }
.head-action { min-width: 120rpx; display: flex; justify-content: flex-end; }
.cmp-btn { padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 22rpx; }
.cmp-btn-on { background: var(--primary, #A855F7); color: #fff; }
.cmp-btn-off { background: var(--muted, #F3E8FF); color: var(--muted-foreground, #6B7280); }
.cmp-exit { padding: 10rpx 20rpx; border-radius: 12rpx; background: var(--muted, #F3E8FF); color: var(--foreground, #1E1B2E); font-size: 22rpx; }

.main { padding: 24rpx; }

.hint {
  margin-bottom: 20rpx; padding: 20rpx; border-radius: 16rpx;
  background: rgba(168,85,247,0.06); border: 2rpx solid rgba(168,85,247,0.12);
  color: var(--foreground, #1E1B2E); font-size: 24rpx;
}
.hint.center { text-align: center; }

.card {
  margin-bottom: 20rpx; border-radius: 24rpx;
  border: 2rpx solid var(--border, #E9D5FF); background: #fff;
  box-shadow: var(--shadow-card, 0 2rpx 12rpx rgba(30,27,46,0.04));
}
.card-inner { display: flex; gap: 16rpx; padding: 24rpx; }

.check {
  width: 40rpx; height: 40rpx; border-radius: 8rpx;
  border: 2rpx solid var(--border, #E9D5FF); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; color: #fff; font-size: 22rpx;
}
.check-on { background: var(--primary, #A855F7); border-color: var(--primary, #A855F7); }

.avatar-wrap { position: relative; }
.avatar {
  width: 104rpx; height: 104rpx; border-radius: 20rpx;
  border: 2rpx solid rgba(168,85,247,0.15);
  background: linear-gradient(135deg, rgba(168,85,247,0.06), rgba(221,214,254,0.12));
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: var(--foreground, #1E1B2E); font-weight: 700;
}
.star { position: absolute; top: -8rpx; right: -8rpx; color: var(--warning, #F59E0B); font-size: 28rpx; }
.info { flex: 1; min-width: 0; }
.name { color: var(--foreground, #1E1B2E); font-size: 30rpx; font-weight: 700; }
.meta { display: block; margin-top: 6rpx; color: var(--muted-foreground, #6B7280); font-size: 22rpx; }

.badges { display: flex; gap: 12rpx; margin: 14rpx 0; }
.badge { padding: 6rpx 14rpx; border-radius: 10rpx; font-size: 22rpx; }
.badge-success { background: rgba(16,185,129,0.12); border: 2rpx solid rgba(16,185,129,0.25); color: var(--success, #10B981); }
.badge-primary { background: rgba(168,85,247,0.08); border: 2rpx solid rgba(168,85,247,0.18); color: var(--primary, #A855F7); }

.tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; }
.tag { padding: 4rpx 12rpx; border-radius: 8rpx; background: var(--muted, #F3E8FF); border: 2rpx solid var(--border, #E9D5FF); font-size: 20rpx; color: var(--foreground, #1E1B2E); }
.more-tag { font-size: 20rpx; color: var(--muted-foreground, #6B7280); }

.chat-btn {
  width: auto; height: 64rpx; line-height: 64rpx;
  border-radius: 14rpx; background: var(--primary, #A855F7); color: #fff;
  font-size: 24rpx; border: none;
  padding: 0 32rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  transition: all 0.2s ease;
}
.chat-btn::after { border: none; }
.chat-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
  box-shadow: 0 2rpx 8rpx rgba(168, 85, 247, 0.4);
}

.compare { padding: 24rpx; }
.compare-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }

.compare-card, .compare-placeholder {
  width: calc(50% - 8rpx); box-sizing: border-box;
  border-radius: 20rpx; border: 2rpx solid var(--primary, #A855F7);
  background: #fff; padding: 20rpx; min-height: 400rpx;
}
.compare-placeholder {
  border-style: dashed; border-color: var(--border, #E9D5FF);
  display: flex; align-items: center; justify-content: center;
  color: var(--muted-foreground, #6B7280); font-size: 22rpx; text-align: center;
}

.compare-avatar {
  width: 120rpx; height: 120rpx; margin: 0 auto 16rpx; border-radius: 20rpx;
  border: 2rpx solid rgba(168,85,247,0.15);
  background: linear-gradient(135deg, rgba(168,85,247,0.06), rgba(221,214,254,0.12));
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: 700; color: var(--foreground, #1E1B2E);
}
.compare-name { text-align: center; color: var(--foreground, #1E1B2E); font-size: 28rpx; font-weight: 700; }
.compare-meta { display: block; text-align: center; margin-top: 6rpx; color: var(--muted-foreground, #6B7280); font-size: 20rpx; }

.compare-scores { margin: 16rpx 0; }
.score-box { border-radius: 12rpx; padding: 12rpx; font-size: 22rpx; margin-bottom: 8rpx; text-align: center; }
.score-box.green { background: rgba(16,185,129,0.10); border: 2rpx solid rgba(16,185,129,0.22); color: var(--success, #10B981); }
.score-box.blue { background: rgba(168,85,247,0.05); border: 2rpx solid rgba(168,85,247,0.14); color: var(--primary, #A855F7); }
.compare-tags { display: flex; flex-wrap: wrap; gap: 6rpx; margin-bottom: 16rpx; }
.compare-card {
  display: flex;
  flex-direction: column;
}

.compare .chat-btn {
  margin-top: auto;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  align-self: flex-end;
}
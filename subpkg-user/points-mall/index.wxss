.mall-page { min-height: 100vh; background: var(--background, #FAF5FF); }

.header {
  position: sticky; top: 0; z-index: 10;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; background: #fff;
  border-bottom: 2rpx solid var(--border, #E9D5FF);
}
.header-left { display: flex; align-items: center; gap: 12rpx; }
.back {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-md, 14rpx);
  border: 2rpx solid var(--border, #E9D5FF); background: var(--muted, #F3E8FF);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: var(--foreground, #1E1B2E);
}
.head-title { color: var(--foreground, #1E1B2E); font-size: 30rpx; font-weight: 700; }

.points-chip {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 20rpx; border-radius: var(--radius-full, 9999rpx);
  border: 2rpx solid var(--warning, #F59E0B); background: var(--warning-light, #FFFBEB);
}
.pts { color: #d97706; font-weight: 700; font-size: 26rpx; }

.content { padding: 24rpx; }

.hero {
  border-radius: var(--radius-2xl, 28rpx); padding: 36rpx; border: none;
  background: var(--gradient-hero, linear-gradient(135deg, #9333EA, #A855F7, #C084FC));
  box-shadow: var(--shadow-lg, 0 8rpx 28rpx rgba(168,85,247,0.18));
  margin-bottom: 24rpx;
}
.hero-label { color: rgba(255,255,255,0.85); font-size: 22rpx; }
.hero-row { display: flex; align-items: flex-end; gap: 8rpx; margin: 12rpx 0 24rpx; }
.hero-num { color: #fff; font-size: 64rpx; font-weight: 900; line-height: 1; }
.hero-unit { color: rgba(255,255,255,0.75); font-size: 24rpx; padding-bottom: 8rpx; }
.hero-btn {
  text-align: center; padding: 18rpx; border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.15); color: #fff; font-size: 24rpx; font-weight: 700;
}

.cat-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.cat-pill {
  display: inline-block; margin-right: 12rpx; padding: 10rpx 22rpx;
  border-radius: var(--radius-full, 9999rpx); border: 2rpx solid var(--border, #E9D5FF);
  background: #fff; color: var(--muted-foreground, #6B7280); font-size: 22rpx;
}
.cat-on { background: var(--primary, #A855F7); color: #fff; border-color: var(--primary, #A855F7); font-weight: 700; }

.product {
  display: flex; gap: 16rpx; padding: 24rpx;
  border-radius: 20rpx; border: 2rpx solid var(--border, #E9D5FF);
  background: #fff; margin-bottom: 16rpx;
}
.p-icon {
  width: 96rpx; height: 96rpx; border-radius: 20rpx;
  border: 2rpx solid var(--border, #E9D5FF);
  background: var(--muted, #F3E8FF);
  display: flex; align-items: center; justify-content: center; font-size: 48rpx;
}
.p-body { flex: 1; min-width: 0; }
.p-name { color: var(--foreground, #1E1B2E); font-size: 26rpx; font-weight: 700; }
.p-meta { margin: 8rpx 0 12rpx; display: flex; align-items: center; gap: 10rpx; }
.p-cat { font-size: 18rpx; padding: 4rpx 12rpx; border-radius: var(--radius-full, 9999rpx); background: var(--primary-50, #F3E8FF); color: var(--primary, #A855F7); font-weight: 600; }
.p-stock { font-size: 18rpx; color: var(--muted-foreground, #6B7280); }
.p-row { display: flex; align-items: center; justify-content: space-between; }
.p-cost { color: #d97706; font-size: 24rpx; font-weight: 700; }
.p-ex { padding: 8rpx 20rpx; border-radius: 14rpx; font-size: 22rpx; }
.p-ex-on { background: var(--primary, #A855F7); color: #fff; border: none; font-weight: 700; }
.p-ex-off { background: var(--muted, #F3E8FF); color: var(--muted-foreground, #6B7280); }

.earn-card {
  margin-top: 8rpx; border-radius: 20rpx;
  border: 2rpx solid var(--border, #E9D5FF); background: #fff; padding: 24rpx;
}
.earn-title { color: var(--foreground, #1E1B2E); font-size: 26rpx; font-weight: 700; margin-bottom: 16rpx; }
.earn-row { display: flex; gap: 16rpx; padding: 16rpx; border-radius: 16rpx; background: var(--muted, #F3E8FF); margin-bottom: 10rpx; }
.earn-emoji { font-size: 36rpx; }
.earn-h { display: block; color: var(--foreground, #1E1B2E); font-size: 24rpx; font-weight: 600; }
.earn-d { display: block; margin-top: 4rpx; color: var(--muted-foreground, #6B7280); font-size: 20rpx; }
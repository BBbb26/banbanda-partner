/** pages/auth/wechat/index.wxss - 紫色主题版 **/

page {
  --background: #FAF5FF;
  --text-main: #1E1B2E;
  --text-muted: #6B7280;
  --primary-color: #A855F7;
  --primary-white: #FFFFFF;
  background-color: var(--background);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
}

.container { height: 100vh; display: flex; flex-direction: column; }

.onboarding-swiper { flex: 1; }
.slide { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; box-sizing: border-box; }

.illustration-box { width: 100%; height: 50vh; display: flex; justify-content: center; align-items: center; position: relative; }
.ip-image { width: 80%; height: 80%; }

.floating { animation: float 3s ease-in-out infinite; }
@keyframes float { 0% { transform: translateY(0); } 50% { transform: translateY(-20rpx); } 100% { transform: translateY(0); } }

.content { width: 100%; text-align: center; margin-top: 60rpx; }

.brand-title {
  display: block; font-size: 80rpx; font-weight: bold;
  color: var(--primary-color, #A855F7);
  margin-bottom: 20rpx; letter-spacing: 4rpx;
}

.title { display: block; font-size: 44rpx; font-weight: 600; color: var(--text-main); margin-bottom: 24rpx; }
.slogan { display: block; font-size: 36rpx; color: var(--text-main); margin-bottom: 16rpx; }
.sub-features { display: block; font-size: 24rpx; color: var(--text-muted); margin-bottom: 60rpx; }
.desc { display: block; font-size: 30rpx; color: var(--text-muted); line-height: 1.6; padding: 0 40rpx; }

.btn { margin-top: 40rpx; border-radius: var(--radius-full, 9999rpx); font-weight: 600; transition: all 0.3s; }
.btn-primary {
  background-color: var(--primary-color, #A855F7);
  color: white; width: 320rpx !important;
  box-shadow: var(--shadow-btn, 0 4rpx 14rpx rgba(168,85,247,0.35));
}
.btn-large { width: 450rpx !important; margin-top: 80rpx; padding: 24rpx 0; }
.btn:active { transform: scale(0.97); opacity: 0.9; }
page {
  background: var(--background, #FAF5FF);
  color: var(--foreground, #1E1B2E);
  font-size: var(--font-lg, 26rpx);
  line-height: 1.6;
}

.campus-page {
  min-height: 100vh;
  display: flex; flex-direction: column;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
}

/* ===== Hero 区域 ===== */
.hero-section { position: relative; background: var(--gradient-warm, linear-gradient(180deg, #F3E8FF 0%, #FAF5FF 100%)); padding-bottom: 0; }

.hero-header {
  position: absolute; top: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 16rpx; z-index: 10;
}

.publish-btn {
  display: flex; align-items: center; gap: 6rpx;
  background: var(--gradient-primary, linear-gradient(135deg, #A855F7, #C084FC));
  color: #fff;
  padding: 14rpx 28rpx; border-radius: var(--radius-full, 9999rpx);
  border: 2rpx solid rgba(255,255,255,0.4);
  box-shadow: var(--shadow-btn, 0 4rpx 14rpx rgba(168,85,247,0.28));
}
.pub-icon { font-size: 30rpx; font-weight: bold; }
.pub-text { font-size: 26rpx; font-weight: 700; }

/* 秋千插画横幅 */
.hero-banner { margin: 4rpx 20rpx 0; border-radius: var(--radius-2xl, 28rpx); overflow: hidden; background: #fff; box-shadow: var(--shadow-md, 0 4rpx 16rpx rgba(168,85,247,0.08)); }
.swing-img { width: 100%; display: block; border-radius: var(--radius-2xl, 28rpx); animation: swingFloat 3s ease-in-out infinite; }

@keyframes swingFloat {
  0% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
  100% { transform: translateY(0); }
}

/* 搜索栏 */
.search-row { padding: 20rpx 24rpx 24rpx; position: relative; z-index: 10; }

.search-box {
  display: flex; align-items: center;
  background: #fff; border: 2rpx solid var(--border, #E9D5FF);
  border-radius: var(--radius-full, 9999rpx);
  padding: 10rpx 18rpx 10rpx 22rpx;
  box-shadow: var(--shadow-xs, 0 1rpx 3rpx rgba(168,85,247,0.05));
}
.search-icon { font-size: 28rpx; flex-shrink: 0; margin-right: 10rpx; }
.search-input { flex: 1; font-size: 27rpx; color: var(--foreground, #1E1B2E); line-height: 44rpx; }
.voice-btn {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: var(--primary-50, #FAF5FF);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-left: 8rpx;
}
.voice-icon { font-size: 26rpx; }

/* ===== Tab 栏 ===== */
.tab-bar {
  background: #fff; border-bottom: 2rpx solid var(--border, #E9D5FF); flex-shrink: 0;
}
.tab-scroll {
  white-space: nowrap;
  display: flex;
  padding: 16rpx 24rpx;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}
.tab-item {
  display: inline-block; font-size: 26rpx; color: var(--muted-foreground, #6B7280);
  padding: 12rpx 28rpx; border-radius: var(--radius-full, 9999rpx);
  margin-right: 16rpx; transition: all 0.25s ease;
  border: 2rpx solid transparent;
}
.tab-item.active {
  color: var(--primary, #A855F7); font-weight: 700;
  background: var(--primary-50, #F3E8FF);
  border-color: var(--primary-200, #E9D5FF);
}

/* ===== 内容流 ===== */
.feed-scroll { flex: 1; overflow: hidden; }
.feed-list { padding: 20rpx 24rpx; }

.post-card {
  background: #fff; border-radius: var(--radius-2xl, 28rpx);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(168,85,247,0.05));
  border: 2rpx solid var(--border, #E9D5FF);
}

/* 用户信息行 */
.post-user { display: flex; align-items: center; gap: 16rpx; margin-bottom: 18rpx; }
.user-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 3rpx solid var(--border, #E9D5FF); flex-shrink: 0;
}
.avatar-emoji { font-size: 38rpx; }
.user-meta { flex: 1; display: flex; flex-direction: column; }
.user-name { font-size: 29rpx; font-weight: 700; color: var(--foreground, #1E1B2E); }
.user-time { font-size: 21rpx; color: var(--muted-foreground, #6B7280); margin-top: 2rpx; }
.follow-btn {
  padding: 10rpx 24rpx; border-radius: 20rpx;
  border: 2rpx solid var(--primary, #A855F7);
  color: var(--primary, #A855F7);
  font-size: 23rpx; font-weight: 600; flex-shrink: 0;
}

/* 正文内容 */
.post-content { font-size: 28rpx; line-height: 1.65; color: var(--foreground, #1E1B2E); display: block; margin-bottom: 16rpx; word-break: break-all; }

/* 配图 */
.post-images { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-bottom: 16rpx; border-radius: 18rpx; overflow: hidden; }
.post-images image:nth-child(1) { grid-column: span 2; grid-row: span 2; }
.post-img { width: 100%; aspect-ratio: 1 / 1; border-radius: 14rpx; }

/* 位置标签 */
.location-tag {
  display: inline-block; font-size: 23rpx; color: var(--muted-foreground, #6B7280);
  background: var(--muted, #F3E8FF); padding: 8rpx 18rpx; border-radius: 12rpx; margin-bottom: 16rpx;
}

/* 互动栏 */
.action-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; flex-wrap: wrap; gap: 12rpx; }
.action-left { display: flex; gap: 28rpx; }
.action-item { display: flex; align-items: center; gap: 8rpx; font-size: 25rpx; color: var(--muted-foreground, #6B7280); }
.action-icon { font-size: 28rpx; }

.emoji-reactions { display: flex; gap: 12rpx; flex-wrap: wrap; }
.react-chip {
  display: flex; align-items: center; gap: 8rpx;
  padding: 10rpx 20rpx;
  background: var(--muted, #F3E8FF);
  border: 2rpx solid var(--border, #E9D5FF);
  border-radius: 20rpx;
  font-size: 24rpx; color: var(--sub, #A1A1AA);
  transition: all 0.2s ease;
}
.react-emoji { font-size: 28rpx; }
.react-label { font-size: 24rpx; font-weight: 600; }
.react-chip:active {
  transform: scale(0.9);
  background: var(--primary, #A855F7);
  border-color: var(--primary, #A855F7);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(168,85,247,0.35);
}

/* CTA 按钮 */
.cta-btn {
  text-align: center;
  background: var(--gradient-hero, linear-gradient(135deg, #9333EA, #A855F7, #C084FC));
  color: #fff; font-size: 28rpx; font-weight: 700;
  padding: 18rpx 0; border-radius: var(--radius-xl, 22rpx);
  border: 2rpx solid var(--border-light, #F3E8FF);
  box-shadow: var(--shadow-btn, 0 4rpx 14rpx rgba(168,85,247,0.20));
}

/* 底部占位 */
.feed-bottom { height: 120rpx; }

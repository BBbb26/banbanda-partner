page {
  background: var(--background, #FAF5FF);
  color: var(--foreground, #1E1B2E);
  font-size: var(--font-lg, 26rpx);
  line-height: 1.5;
}

.home-page {
  min-height: 100vh;
  padding-bottom: 200rpx;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
}

/* ===== 头部区域 ===== */
.header-section {
  background: var(--gradient-warm, linear-gradient(180deg, #F3E8FF 0%, #FAF5FF 100%));
  padding-bottom: 8rpx;
}

.header-decoration {
  height: 8rpx;
  background: linear-gradient(90deg, var(--primary, #A855F7) 0%, var(--primary-light, #C084FC) 50%, var(--warning, #F59E0B) 100%);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-wrapper { position: relative; }

.avatar-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-100, #F3E8FF) 0%, var(--primary-50, #FAF5FF) 100%);
  border: 3rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(168,85,247,0.10));
}

.avatar-ring {
  position: absolute;
  top: -4rpx; left: -4rpx; right: -4rpx; bottom: -4rpx;
  border-radius: 50%;
  border: 2rpx solid var(--primary, #A855F7);
  opacity: 0.35;
}

.avatar-face { font-size: 36rpx; }

.greeting-wrapper { display: flex; flex-direction: column; }

.header-greeting {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--foreground, #1E1B2E);
  line-height: 1.2;
}

.header-sub-greeting {
  font-size: 22rpx;
  color: var(--muted-foreground, #6B7280);
}

.header-right { display: flex; align-items: center; gap: 16rpx; }

.campus-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--primary, #A855F7);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: var(--shadow-btn, 0 4rpx 14rpx rgba(168,85,247,0.28));
}

.campus-icon { font-size: 22rpx; }

/* 搜索栏 */
.search-wrapper { padding: 0 24rpx 16rpx; }

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid var(--border, #E9D5FF);
  border-radius: 32rpx;
  padding: 16rpx 20rpx;
  box-shadow: var(--shadow-xs, 0 1rpx 3rpx rgba(168,85,247,0.05));
}

.location-picker { display: flex; align-items: center; gap: 6rpx; flex-shrink: 0; }
.loc-icon { font-size: 24rpx; }
.loc-text { font-size: 24rpx; color: var(--foreground, #1E1B2E); font-weight: 600; max-width: 140rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.loc-arrow { font-size: 18rpx; color: var(--muted-foreground, #6B7280); }
.search-divider { width: 2rpx; height: 32rpx; background: var(--border, #E9D5FF); margin: 0 16rpx; }
.search-input { flex: 1; font-size: 26rpx; color: var(--foreground, #1E1B2E); height: 48rpx; line-height: 48rpx; }
.search-placeholder { color: var(--muted-foreground, #6B7280); font-size: 24rpx; }
.search-icon-wrap {
  width: 44rpx; height: 44rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--primary, #A855F7);
  border-radius: 50%;
  flex-shrink: 0;
}
.search-icon { font-size: 22rpx; }

/* ===== 分类图标行 ===== */
.category-row {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 20rpx 16rpx;
  background: var(--background, #FAF5FF);
}

.category-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; width: 140rpx; }
.cat-image { width: 110rpx; height: 100rpx; border-radius: 20rpx; }
.cat-label { font-size: 24rpx; color: var(--foreground, #1E1B2E); font-weight: 600; }

/* ===== 热门活动区域 ===== */
.activity-section { padding: 20rpx 0 16rpx; }

.section-header-bar { display: flex; align-items: center; justify-content: space-between; padding: 0 28rpx 16rpx; }
.section-header-bar .header-left { display: flex; align-items: center; gap: 12rpx; }

.live-indicator {
  display: flex; align-items: center; gap: 8rpx;
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  padding: 6rpx 14rpx; border-radius: 20rpx;
}

.pulse-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: var(--primary, #A855F7);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.8); }
}

.live-text { font-size: 20rpx; font-weight: 600; color: var(--primary, #A855F7); }
.section-title { font-size: 28rpx; font-weight: 700; color: var(--foreground, #1E1B2E); }
.activity-more { display: flex; align-items: center; gap: 4rpx; font-size: 24rpx; color: var(--muted-foreground, #6B7280); }
.arrow { font-size: 28rpx; color: var(--primary, #A855F7); }

.activity-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}
.activity-list { display: inline-flex; gap: 20rpx; }

.activity-card {
  width: 280rpx;
  background: #fff;
  border-radius: var(--radius-2xl, 28rpx);
  padding: 20rpx;
  border: 2rpx solid var(--border, #E9D5FF);
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(168,85,247,0.06));
  flex-shrink: 0;
}

.activity-card.urgent {
  border-color: var(--primary, #A855F7);
  background: linear-gradient(180deg, #FFF9F9 0%, #fff 100%);
}

.activity-badge-wrap { display: flex; align-items: center; gap: 8rpx; margin-bottom: 12rpx; }
.activity-badge { font-size: 18rpx; font-weight: 700; color: #fff; padding: 4rpx 12rpx; border-radius: 10rpx; }
.urgent-tag {
  font-size: 16rpx; font-weight: 700; color: #fff;
  background: var(--primary, #A855F7);
  padding: 4rpx 10rpx; border-radius: 8rpx;
  animation: urgentPulse 1s ease-in-out infinite;
}

@keyframes urgentPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }

.activity-main { margin-bottom: 14rpx; }
.activity-type { font-size: 20rpx; color: var(--muted-foreground, #6B7280); display: block; margin-bottom: 4rpx; }
.activity-name { font-size: 26rpx; font-weight: 700; color: var(--foreground, #1E1B2E); display: block; }

.activity-meta-grid { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 14rpx; }
.meta-item { display: flex; align-items: center; gap: 6rpx; }
.meta-icon { font-size: 20rpx; }
.meta-text { font-size: 22rpx; color: var(--muted-foreground, #6B7280); }

.activity-footer { display: flex; align-items: center; justify-content: space-between; }
.member-stack { display: flex; align-items: center; }

.stack-avatar {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  border: 3rpx solid #fff; margin-left: -10rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: #fff; font-weight: 700;
}
.stack-avatar:first-child { margin-left: 0; }
.more-avatar { background: var(--muted, #F3E8FF); color: var(--muted-foreground, #6B7280); }
.member-count { font-size: 22rpx; color: var(--muted-foreground, #6B7280); font-weight: 600; }

/* ===== 精选推荐 ===== */
.recommend-section { padding: 0 24rpx; }

.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.section-header .header-left { display: flex; align-items: center; gap: 10rpx; }
.header-icon { font-size: 32rpx; }

.filter-tabs { display: flex; gap: 12rpx; }
.filter-tab {
  font-size: 22rpx; color: var(--muted-foreground, #6B7280);
  padding: 8rpx 16rpx; border-radius: 20rpx;
  background: var(--muted, #F3E8FF);
  transition: all 0.2s ease;
}
.filter-tab.active {
  background: var(--primary, #A855F7);
  color: #fff;
  font-weight: 600;
}

.waterfall-container { display: flex; gap: 20rpx; }
.waterfall-col { flex: 1; display: flex; flex-direction: column; gap: 20rpx; }

.recommend-card {
  background: #fff;
  border-radius: var(--radius-2xl, 28rpx);
  overflow: hidden;
  box-shadow: var(--shadow-card, 0 2rpx 12rpx rgba(30,27,46,0.05));
  position: relative;
}

.user-card { border: 2rpx solid var(--border, #E9D5FF); }

.card-cover {
  height: 200rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.cover-main { z-index: 2; }
.cover-emoji { font-size: 80rpx; }

.cover-overlay {
  position: absolute; top: 0; right: 0; bottom: 0; width: 50%;
  background: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.15) 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rpx;
}

.match-badge { display: flex; align-items: baseline; gap: 2rpx; }
.match-value { font-size: 36rpx; font-weight: 800; color: #fff; }
.match-unit { font-size: 20rpx; color: #fff; }
.match-label { font-size: 18rpx; color: rgba(255,255,255,0.9); }

.card-body { padding: 18rpx; }

.user-info-row { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12rpx; }
.user-main { flex: 1; }
.user-name { font-size: 28rpx; font-weight: 700; color: var(--foreground, #1E1B2E); display: block; margin-bottom: 6rpx; }

.user-tags { display: flex; align-items: center; gap: 8rpx; }
.user-grade {
  font-size: 18rpx; color: var(--primary, #A855F7);
  background: var(--primary-50, #FAF5FF);
  padding: 2rpx 10rpx; border-radius: 8rpx;
}
.user-school { font-size: 18rpx; color: var(--muted-foreground, #6B7280); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.reliability-badge {
  display: flex; align-items: center; gap: 4rpx;
  background: var(--success-bg, #ECFDF5);
  padding: 4rpx 10rpx; border-radius: 12rpx;
}
.shield-icon { font-size: 18rpx; }
.reliability-badge .score { font-size: 20rpx; font-weight: 700; color: var(--success, #10B981); }

.tags-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.tag {
  font-size: 20rpx; color: var(--muted-foreground, #6B7280);
  background: var(--muted, #F3E8FF);
  padding: 4rpx 12rpx; border-radius: 10rpx;
}

.match-reason-row {
  display: flex; align-items: flex-start; gap: 6rpx;
  background: var(--warning-light, #FFFBEB);
  padding: 10rpx 12rpx; border-radius: 12rpx;
  margin-bottom: 14rpx;
}
.match-reason-icon { font-size: 18rpx; flex-shrink: 0; }
.match-reason { font-size: 20rpx; color: #92400e; line-height: 1.4; }

.card-footer { 
  display: flex; 
  flex-direction: column; 
  gap: 12rpx;
}

.footer-row {
  display: flex;
  align-items: center;
}

/* 信息行：头像左对齐，文字右对齐 */
.info-row {
  justify-content: space-between;
}

.info-row .social-proof {
  width: 100%;
  justify-content: space-between;
}

.btn-row {
  justify-content: center;
}

.social-proof { display: flex; align-items: center; gap: 8rpx; }
.mini-avatars { display: flex; }
.mini-avatar {
  width: 28rpx; height: 28rpx; border-radius: 50%;
  border: 2rpx solid #fff; margin-left: -8rpx;
}
.mini-avatar:first-child { margin-left: 0; }
.social-text { font-size: 20rpx; color: var(--muted-foreground, #6B7280); }

.action-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 6rpx;
  background: var(--primary, #A855F7);
  color: #fff;
  padding: 10rpx 24rpx; border-radius: 20rpx;
  box-shadow: var(--shadow-btn, 0 4rpx 14rpx rgba(168,85,247,0.25));
  transition: all 0.2s ease;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}

/* 点击交互特效 */
.action-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.4s ease, height 0.4s ease;
}

.action-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(168, 85, 247, 0.4);
}

.action-btn:active::after {
  width: 200%;
  height: 200%;
}

/* 发起对话按钮 - 缩小尺寸 */
.action-btn.chat-btn {
  min-width: 140rpx;
  height: 52rpx;
}

.btn-icon { font-size: 20rpx; flex-shrink: 0; color: #fff; }
.btn-text { font-size: 20rpx; font-weight: 600; letter-spacing: 1rpx; color: #fff; }

.fav-btn {
  position: absolute; top: 12rpx; right: 12rpx;
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex; align-items: center; justify-content: center;
  z-index: 5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.fav-icon { font-size: 28rpx; color: #DDD6FE; }
.fav-icon.active { color: var(--primary, #A855F7); }

/* 广告卡片 */
.ad-card { border: 2rpx dashed var(--border, #E9D5FF); }
.ad-badge-small {
  position: absolute; top: 12rpx; left: 12rpx;
  background: rgba(0, 0, 0, 0.5); color: #fff;
  font-size: 16rpx; font-weight: 700;
  padding: 4rpx 10rpx; border-radius: 8rpx; z-index: 5;
}
.ad-cover { height: 160rpx; }
.ad-logo-emoji { font-size: 64rpx; }
.ad-title { font-size: 26rpx; font-weight: 700; color: var(--foreground, #1E1B2E); display: block; margin-bottom: 6rpx; }
.ad-offer-row { margin-bottom: 8rpx; }
.ad-offer {
  font-size: 22rpx; color: var(--success, #10B981); font-weight: 700;
  background: var(--success-bg, #ECFDF5);
  padding: 4rpx 10rpx; border-radius: 8rpx; display: inline-block;
}
.ad-location { display: flex; align-items: center; gap: 4rpx; }
.loc-pin { font-size: 18rpx; }
.loc-name { font-size: 20rpx; color: var(--muted-foreground, #6B7280); }

/* ===== FAB ===== */
.fab {
  position: fixed; right: 28rpx; bottom: 180rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: var(--gradient-hero, linear-gradient(135deg, #9333EA, #A855F7, #C084FC));
  color: #fff;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  box-shadow: var(--shadow-xl, 0 16rpx 48rpx rgba(168,85,247,0.30));
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  z-index: 99;
}
.fab-icon { font-size: 36rpx; font-weight: 300; line-height: 1; }
.fab-text { font-size: 18rpx; font-weight: 600; margin-top: 2rpx; }

/* ===== 大学选择器弹窗 ===== */
.school-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.school-picker-content {
  width: 100%;
  height: 80vh;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.school-picker-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 28rpx 24rpx;
  border-bottom: 2rpx solid var(--border, #E9D5FF);
}
.school-picker-title { font-size: 32rpx; font-weight: 700; color: var(--foreground, #1E1B2E); }
.school-picker-close { font-size: 48rpx; color: var(--muted-foreground, #6B7280); line-height: 1; }

.school-search {
  margin: 24rpx 28rpx; background: var(--muted, #F3E8FF);
  border-radius: 24rpx; padding: 16rpx 24rpx;
  display: flex; align-items: center; gap: 12rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  flex-shrink: 0; /* 不被压缩 */
}
.school-search-icon { font-size: 28rpx; flex-shrink: 0; }
.school-search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--foreground, #1E1B2E);
  min-width: 0;
  height: 48rpx;
  line-height: 48rpx;
}

.school-list {
  flex: 1;
  height: 0;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}
.school-item {
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  display: flex; align-items: center; justify-content: space-between;
}
.school-item.selected {
  background: #F3E8FF;
}
.school-item-name { font-size: 28rpx; color: var(--foreground, #1E1B2E); }
.school-item-check { font-size: 28rpx; color: var(--primary, #A855F7); }

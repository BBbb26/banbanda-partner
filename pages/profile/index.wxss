.profile-page {
  min-height: 100vh;
  padding: 0 24rpx;
  background: var(--background, #FAF5FF);
}

/* ================================
   Hero 区域 — 左右布局（参考截图2）
   ================================ */
.hero {
  margin: 0 -24rpx; padding: 36rpx 24rpx 28rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #9333EA 50%, #A855F7 100%);
  border-bottom-left-radius: 32rpx;
  border-bottom-right-radius: 32rpx;
}

/* 主信息行：头像左 + 信息右 */
.hero-main {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

/* 左侧：头像 */
.hero-left {
  position: relative;
  flex-shrink: 0;
}

.avatar-box {
  width: 130rpx;
  height: 130rpx;
  border-radius: 26rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}

.avatar-emoji { font-size: 64rpx; line-height: 1; }

/* 认证徽章（绿色圆圈勾） */
.verify-badge {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: var(--success, #10B981);
  border: 3rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(16,185,129,0.35);
}

.verify-icon {
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
}

/* 右侧：个人信息 */
.hero-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding-top: 4rpx;
}

.top-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

.verified-tag {
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 3px 12rpx;
  border-radius: 8rpx;
}

.edit-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
  flex-shrink: 0;
}

.edit-icon { font-size: 30rpx; color: rgba(255,255,255,0.85); }

.school-info {
  font-size: 25rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 8rpx;
  display: block;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.star-icon { font-size: 26rpx; color: #FBBF24; line-height: 1; }
.score-num {
  font-size: 32rpx;
  font-weight: 800;
  color: #FBBF24;
  line-height: 1;
}

/* ===== 统计卡片行 ===== */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: rgba(255,255,255,0.18);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  backdrop-filter: blur(8rpx);
}

.stat-tappable { cursor: pointer; }
.stat-tappable:active { opacity: 0.85; transform: scale(0.97); transition: all 0.15s; }

.stat-icon { font-size: 36rpx; margin-bottom: 6rpx; }
.stat-val {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}
.stat-label {
  font-size: 21rpx;
  color: rgba(255,255,255,0.78);
  margin-top: 4rpx;
}

/* ================================
   VIP 卡片
   ================================ */
.vip-card {
  margin-top: 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border: 2rpx solid #FCD34D;
  padding: 24rpx;
}

.vip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.vip-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #92400E;
}

.vip-badge-tag {
  font-size: 18rpx;
  font-weight: 700;
  color: #DC2626;
  background: #FEE2E2;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.vip-sub {
  display: block;
  color: #B45309;
  font-size: 23rpx;
  margin-top: 6rpx;
  margin-bottom: 14rpx;
}

.vip-btn {
  display: inline-block;
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 12rpx 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(217,119,6,0.3);
}

.vip-card:active .vip-btn { opacity: 0.9; transform: scale(0.97); }

/* ================================
   菜单功能列表
   ================================ */
.menu-section {
  margin-top: 20rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--border, #E9D5FF);
}

.menu-item {
  padding: 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid var(--border-light, #F3E8FF);
}
.menu-item:last-child { border-bottom: none; }

.menu-icon { font-size: 32rpx; width: 48rpx; flex-shrink: 0; text-align: center; }
.menu-label {
  margin-left: 16rpx;
  flex: 1;
  color: var(--foreground, #1E1B2E);
  font-size: 28rpx;
  font-weight: 600;
}
.arrow {
  color: var(--muted-foreground, #6B7280);
  font-size: 32rpx;
  flex-shrink: 0;
}

/* ================================
   安全与认证区域（参考截图1）
   ================================ */
.security-section {
  margin-top: 20rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--border, #E9D5FF);
}

.sec-item {
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid var(--border-light, #F3E8FF);
}
.sec-item:last-child { border-bottom: none; }

.sec-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.sec-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sec-blue { background: #EFF6FF; }
.sec-yellow { background: #FEFCE8; }

.sec-icon { font-size: 32rpx; }
.sec-yellow .sec-icon {
  font-size: 20rpx;
  font-weight: 900;
  color: #D97706;
  letter-spacing: -1rpx;
}

.sec-body { min-width: 0; }

.sec-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--foreground, #1E1B2E);
  display: block;
}

.sec-desc {
  font-size: 22rpx;
  color: var(--muted-foreground, #6B7280);
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 已认证状态标签 */
.auth-status {
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
  white-space: nowrap;
}

.verified-status {
  background: #ECFDF5;
  color: var(--success, #10B981);
  border: 2rpx solid #A7F3D0;
}

/* 底部安全间距 */
.bottom-spacer { height: 40rpx; }

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: var(--card, #FFFFFF);
  border-top: 2rpx solid var(--border, #E9D5FF);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-inner {
  height: 110rpx;
  display: flex;
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
}

.tab-icon {
  width: 52rpx;
  height: 52rpx;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-icon-active {
  transform: scale(1.15);
}

@keyframes tabBounce {
  0% { transform: scale(1); }
  40% { transform: scale(1.35); }
  70% { transform: scale(0.92); }
  100% { transform: scale(1.15); }
}

.icon-bounce {
  animation: tabBounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.tab-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--muted-foreground, #6B7280);
  transition: transform 0.25s ease, opacity 0.25s ease;
}

.tab-pop .tab-text {
  animation: textPop 0.35s ease;
}

@keyframes textPop {
  0% { opacity: 0.6; transform: translateY(4rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: var(--primary, #A855F7);
}
